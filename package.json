{
  "name": "changex-motion-ts",
  "version": "1.0.0",
  "private": true,
  "description": "基于 Remotion + Three.js 的交互式教程视频制作项目",
  "scripts": {
    "start": "remotion studio",
    "studio": "remotion studio",
    "render": "remotion render",
    "render:git": "remotion render GitTutorial out/git/git-$(date +%Y%m%d-%H%M).mp4",
    "render:docker": "remotion render DockerTutorial out/docker/docker-$(date +%Y%m%d-%H%M).mp4",
    "render:photosynthesis": "remotion render Photosynthesis out/photosynthesis/photosynthesis-$(date +%Y%m%d-%H%M).mp4",
    "render:all": "npm run render:git && npm run render:docker && npm run render:photosynthesis"
  },
  "dependencies": {
    "@react-three/drei": "^9.120.0",
    "@react-three/fiber": "^8.17.0",
    "@remotion/cli": "4.0.429",
    "@remotion/lottie": "4.0.429",
    "@remotion/player": "4.0.429",
    "@remotion/three": "4.0.429",
    "lottie-web": "^5.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "4.0.429",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0"
  }
}
